# Fit mixed models: base model and interaction test
# Strategy: fit linear mixed model with Animal as random intercept and fixed effects Treatment, Period, and interaction.

# Prepare results container
results_list <- list()

sink("mixed_model_results__Nit_Eff_8C.txt")

for (resp in response_vars) {
  cat("\n===== ANALYSIS for", resp, "=====\n")
  formula_str <- paste0(resp, " ~ Treatment * Period + (1 | Animal_No)")
  cat("Model formula:", formula_str, "\n")
  
  # Wrap each model fit in tryCatch so a single failure doesn't stop the loop
  fit_res <- tryCatch({
    model <- lmer(as.formula(formula_str), data = df, REML = FALSE)
    
    # Tidy fixed effects (broom.mixed)
    model_summary <- tryCatch(
      broom.mixed::tidy(model, effects = "fixed"),
      error = function(e) {
        warning("broom.mixed::tidy failed for ", resp, " : ", e$message)
        NULL
      }
    )
    
    # ANOVA (type 3)
    anova_tab <- tryCatch(
      anova(model, type = 3),
      error = function(e) {
        warning("anova() failed for ", resp, " : ", e$message)
        NULL
      }
    )
    
    # emmeans and pairwise contrasts (may fail if model degenerate)
    emm <- tryCatch(
      emmeans::emmeans(model, ~ Treatment | Period),
      error = function(e) {
        warning("emmeans() failed for ", resp, " : ", e$message)
        NULL
      }
    )
    
    pairs_df <- NULL
    if (!is.null(emm)) {
      pairs_df <- tryCatch(
        as.data.frame(pairs(emm, adjust = "tukey")),
        error = function(e) {
          warning("pairs() failed for ", resp, " : ", e$message)
          NULL
        }
      )
    }
    
    # Print outputs to sink (if present)
    print(summary(model))
    if (!is.null(anova_tab)) print(anova_tab)
    if (!is.null(emm)) print(emm)
    if (!is.null(pairs_df)) print(pairs_df)
    
    # Return a list of the results to be stored
    list(
      success = TRUE,
      model = model,
      model_summary = model_summary,
      anova = anova_tab,
      emm = emm,
      pairs = pairs_df
    )
    
  }, error = function(e) {
    # If model fitting itself fails, capture the error but continue
    warning("Model fit failed for ", resp, " : ", e$message)
    list(success = FALSE, error = e$message)
  })
  
  # Store in results_list under the response name
  results_list[[resp]] <- fit_res
} # end loop

sink()  # stop capturing output


##

# Save results for later (useful for excel export)  
saveRDS(results_list, file = "results_list_mixed_models_Nit_eff_8C.rds")

wb <- createWorkbook()
for (resp in names(results_list)) {
  res <- results_list[[resp]]
  if (!is.null(res) && isTRUE(res$success)) {
    addWorksheet(wb, resp)
    writeData(wb, resp, paste("Model Summary for", resp), startRow = 1)
    if (!is.null(res$model_summary)) writeData(wb, resp, res$model_summary, startRow = 2)
    start_row <- ifelse(is.null(res$model_summary), 5, nrow(res$model_summary) + 5)
    writeData(wb, resp, paste("Estimated Marginal Means for", resp), startRow = start_row)
    if (!is.null(res$emm)) writeData(wb, resp, as.data.frame(res$emm), startRow = start_row + 1)
    if (!is.null(res$pairs)) {
      start_row2 <- start_row + 1 + nrow(as.data.frame(res$emm))
      writeData(wb, resp, "Pairwise Contrasts (Tukey)", startRow = start_row2)
      writeData(wb, resp, res$pairs, startRow = start_row2 + 1)
    }
  } else {
    # optional: create a sheet explaining failure
    addWorksheet(wb, resp)
    writeData(wb, resp, paste("Model failed for", resp, ":", res$error), startRow = 1)
  }
}
saveWorkbook(wb, "Mixed_Model_Results_Nit_eff_8C.xlsx", overwrite = TRUE)


