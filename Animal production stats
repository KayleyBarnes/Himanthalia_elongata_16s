# Robust helper to extract p-values for Treatment, Period and Treatment:Period
get_pvals <- function(response_name, data = df,
                      formula_template = "{resp} ~ Treatment * Period + (1|Animal_No)",
                      REML = FALSE) {
  # Build formula
  form <- as.formula(glue::glue(formula_template, resp = response_name))
  
  # Fit model (try a few times if needed)
  model <- tryCatch(
    lme4::lmer(form, data = data, REML = REML),
    error = function(e) {
      warning("lmer failed for ", response_name, " : ", e$message)
      return(NULL)
    }
  )
  
  if (is.null(model)) {
    return(tibble::tibble(
      Response = response_name,
      p_Treatment = NA_real_,
      p_Period = NA_real_,
      p_Interaction = NA_real_,
      note = "model_failed"
    ))
  }
  
  # Try extracting ANOVA (type III preferable). Try multiple fallbacks to be robust.
  anova_tab <- NULL
  anova_note <- NULL
  # 1) try lmerTest::anova (Type III, Satterthwaite ddf)
  anova_tab <- tryCatch({
    # lmerTest::anova will usually return a data.frame / matrix with a p-value column
    lmerTest::anova(model, type = 3, ddf = "Satterthwaite")
  }, error = function(e) {
    anova_note <<- paste("lmerTest::anova failed:", e$message)
    NULL
  })
  
  # 2) fallback to car::Anova (Type III)
  if (is.null(anova_tab)) {
    anova_tab <- tryCatch({
      car::Anova(model, type = 3)
    }, error = function(e) {
      anova_note <<- paste(anova_note, " ; car::Anova failed:", e$message)
      NULL
    })
  }
  
  # 3) fallback to stats::anova (may give LR/Chisq; often missing p-values)
  if (is.null(anova_tab)) {
    anova_tab <- tryCatch({
      stats::anova(model)
    }, error = function(e) {
      anova_note <<- paste(anova_note, " ; stats::anova failed:", e$message)
      NULL
    })
  }
  
  # If still no anova, return NA pvals
  if (is.null(anova_tab)) {
    return(tibble::tibble(
      Response = response_name,
      p_Treatment = NA_real_,
      p_Period = NA_real_,
      p_Interaction = NA_real_,
      note = paste("anova_failed:", anova_note)
    ))
  }
  
  # Make sure anova_tab is a data frame and rownames are accessible
  anova_df <- as.data.frame(anova_tab)
  rownames_vec <- rownames(anova_df)
  
  # Find a suitable p-value column (common names)
  p_col_candidates <- intersect(c("Pr(>F)", "Pr(>Chisq)", "Pr...F.", "Pr...Chisq.", "p.value", "Pr(>F)"), colnames(anova_df))
  if (length(p_col_candidates) == 0) {
    # more general search for column containing "Pr" or "p"
    p_col_candidates <- grep("Pr|p\\.value|p.value|pval|P", colnames(anova_df), value = TRUE, ignore.case = TRUE)
  }
  p_col <- if (length(p_col_candidates) > 0) p_col_candidates[1] else NA_character_
  
  extract_p <- function(term_name) {
    # try exact match in rownames; if not found, try grepping
    idx <- which(rownames_vec == term_name)
    if (length(idx) == 0) idx <- grep(paste0("^", term_name, "$"), rownames_vec, ignore.case = TRUE)
    if (length(idx) == 0) idx <- grep(term_name, rownames_vec, ignore.case = TRUE)
    if (length(idx) == 0) return(NA_real_)
    if (is.na(p_col)) return(NA_real_)
    val <- anova_df[idx[1], p_col]
    as.numeric(val)
  }
  
  p_Treatment <- extract_p("Treatment")
  p_Period <- extract_p("Period")
  p_Interaction <- extract_p("Treatment:Period")
  
  # Some anova outputs list the interaction as "Treatment:Period" or "Period:Treatment"
  if (is.na(p_Interaction)) {
    p_Interaction <- extract_p("Period:Treatment")
  }
  
  # Final tidy tibble
  res <- tibble::tibble(
    Response = response_name,
    p_Treatment = p_Treatment,
    p_Period = p_Period,
    p_Interaction = p_Interaction,
    note = ifelse(is.null(anova_note), NA_character_, anova_note)
  )
  return(res)
}

