responses <- names(df)[which(names(df) == "Milk") : ncol(df)]

responses

# Compute p-values
pvals <- map_df(responses, get_pvals)

head(pvals)

# 2. Compute Mean ± SD by Treatment
desc <- df %>%
  pivot_longer(all_of(responses), names_to = "Response", values_to = "Value") %>%
  group_by(Response, Treatment) %>%
  summarise(
    Mean = mean(Value, na.rm = TRUE),
    SD   = sd(Value, na.rm = TRUE),
    n    = n(),
    SE   = SD / sqrt(n),
    Mean_SD = sprintf("%.2f ± %.2f", Mean, SD),
    .groups = "drop"
  )

head(desc)

# 3. Reshape wide
table_wide <- desc %>%
  dplyr::select(Response, Treatment, Mean_SD) %>%
  pivot_wider(
    names_from = Treatment,
    values_from = Mean_SD
  )

# 4. Add SE column
se_vals <- desc %>%
  group_by(Response) %>%
  summarise(SE = mean(SE), .groups = "drop")

# 5. Combine descriptive stats + p-values
final_table <- table_wide %>%
  dplyr::left_join(se_vals, by = "Response") %>%
  dplyr::left_join(pvals, by = "Response") %>%
  dplyr::select(Response, CON, HE, XHE, SE,
                p_Treatment, p_Period, p_Interaction)

print(final_table)

# Export to CSV
write.csv(final_table, "E55_interaction_stats_table_Nit_Eff_8C.csv", row.names = FALSE)

### Compact letter generation. Compact letter generated for response variable 'UN' which wasn't deemed significantly different from earlier tests. Please explain reasoning. 


check_assumptions <- function(model, data, response, treatment_var = "Treatment") {
  
  cat("\n\n==============================\n")
  cat("Assumption checks for:", response, "\n")
  cat("==============================\n")
  
  # Extract residuals
  res <- residuals(model)
  
  # Shapiro–Wilk normality test
  cat("\nShapiro-Wilk Normality Test:\n")
  print(shapiro.test(res))
  
  # QQ-plot
  qqnorm(res); qqline(res, col = "red")
  
  # Homogeneity of variance
  cat("\nLevene Test (Homogeneity of Variance across Treatment):\n")
  levene_formula <- as.formula(paste(response, "~", treatment_var))
  print(leveneTest(levene_formula, data = data))
}


results <- list()

for (resp in response_vars) {
  
  # Construct model formula
  form <- as.formula(paste(resp, "~ Treatment + Period + (1|Animal_No)"))
  
  # Fit mixed model
  model <- lmer(form, data = df)
  
  # Save model
  results[[resp]] <- model
  
  # Print summary
  cat("\n\n====================================================\n")
  cat("Linear Mixed Model for:", resp, "\n")
  cat("====================================================\n")
  print(summary(model))
  
  # Assumption checks
  check_assumptions(model, df, resp)
  
  # Estimated marginal means for Treatment
  em <- emmeans(model, ~ Treatment)
  
  # Compact letter display (Treatment only)
  cat("\nCompact Letter Display (Treatment differences):\n")
  print(cld(em, Letters = letters))
}


cld_list <- lapply(names(results), function(resp) {
  model <- results[[resp]]
  em <- emmeans(model, ~ Treatment)
  cld_table <- cld(em, Letters = letters)
  cld_table$response <- resp
  return(cld_table)
})

cld_output <- bind_rows(cld_list)

write.csv(cld_output, "Treatment_CLD_results_nit_eff_8C.csv", row.names = FALSE)







