## Script for used for animal production, gaseous exchange, nitrogen use efficiency, rumen fermenation parameters. 

# load data
df <- Nit_Eff_8C

# Convert to factors, dependent and independent variables, ensure variables are named the same as the column names. otherwise it will create a duplicate.

df <- df %>%
  mutate(
    Animal_No = as.factor(Animal_No),   
    Treatment = as.factor(Treatment),
    Period = as.factor(Period)         
  )

# Exploratory plots (per response variable, change "Milk") 
response_vars <- names(df)[which(names(df) == "Milk") : ncol(df)]
response_vars

# Boxplots by Treatment and Period
for (resp in response_vars){
  p <- ggplot(df, aes(x=Treatment, y = .data[[resp]], fill = Treatment)) +
    geom_boxplot(alpha=0.6) +
    facet_wrap(~Period) +
    ggtitle(paste("Boxplot of", resp, "by Treatment and Period")) +
    theme_minimal()
  print(p)
}

# Subject-level spaghetti plot (connect repeated measures)
for (resp in response_vars){
  p <- ggplot(df, aes(x = Period, y = .data[[resp]], group = Animal_No, color = Treatment)) +
    geom_point() + geom_line(alpha = 0.6) +
    ggtitle(paste("Repeated measures for", resp)) +
    theme_minimal()
  print(p)
}

# Check normality and homogeneity of variances

## Visual normality of residuals: histogram + QQ plot per response
for (resp in response_vars){
  v <- df[[resp]]
  cat("\n---", resp, "---\n")
  print(ggqqplot(v, title = paste("QQ plot for", resp)))
  print(ggdensity(v, main = paste("Density for", resp)))
  # Shapiro-Wilk test (note: sensitive for small sample sizes; do per-group if needed)
  sh <- tryCatch(shapiro.test(v), error = function(e) NULL)
  print(sh)
}

## Levene's test for homogeneity across Treatment and across Period
for (resp in response_vars){
  cat("\nLevene tests for", resp, "\n")
  lev_treat <- leveneTest(as.formula(paste(resp, "~ Treatment")), data = df)
  print(lev_treat)
  lev_period <- leveneTest(as.formula(paste(resp, "~ Period")), data = df)
  print(lev_period)
}

# Levene by treatment × period cells (if some cells have very small n, interpret with caution)
for (resp in response_vars){
  df$cell <- interaction(df$Treatment, df$Period)
  cat("\nLevene for cells (Treatment:Period) -", resp, "\n")
  print(leveneTest(as.formula(paste(resp, "~ cell")), data = df))
  df$cell <- NULL
}


